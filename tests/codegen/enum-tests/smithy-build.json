      "transforms": [
        {
          "name": "includeServices",
          "args": {
            "services": [
              "smithy.kotlin.enums#EnumTestService"
            ]
          }
        }
      ],
      "plugins": {
        "kotlin-codegen": {
          "service": "smithy.kotlin.enums#EnumTestService",
