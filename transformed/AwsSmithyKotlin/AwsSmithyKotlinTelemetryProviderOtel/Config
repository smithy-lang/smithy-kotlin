# -*-perl-*-

package.AwsSmithyKotlinTelemetryProviderOtel = {
    interfaces = (1.0.x);

    third-party-configuration = {
        thirdPartyName    = "aws.smithy.kotlin:telemetry-provider-otel-jvm";
        thirdPartyVersion = "1.6.10";
        licenseType       = (Apache-2.0);
        licenseFile       = (https://www.apache.org/licenses/LICENSE-2.0.txt);
        repository        = maven;
        downloadType      = binaries;
    };

    build-system = copysrc;

    build-tools = {
        1.0.x = {
            CopySrcBuild = 1.0;
        };
    };

    dependencies = {
        1.0.x = {
            Maven-io-opentelemetry_opentelemetry-api              = 1.x;
            Maven-io-opentelemetry_opentelemetry-extension-kotlin = 1.x;
            AwsSmithyKotlinTelemetryApi                           = 1.0.x;
            KotlinStdlib                                          = 2.x;
        };
    };

    runtime-dependencies = {
        1.0.x = {
            KotlinxCoroutinesCoreJvm         = 1.x;
            AwsSmithyKotlinTelemetryDefaults = 1.0.x;
        };
    };

    resolves-conflict-dependencies = {
        1.0.x = {
            KotlinxCoroutinesCoreJvm = 1.x;
        };
    };

    targets = {
        telemetry-provider-otel-jvm = { type = javalibrary; };
    };
};
