# -*-perl-*-

package.AwsSmithyKotlinHttpClientEngineOkhttp = {
    interfaces = (1.0.x);

    third-party-configuration = {
        thirdPartyName    = "aws.smithy.kotlin:http-client-engine-okhttp-jvm";
        thirdPartyVersion = "1.6.10";
        licenseType       = (Apache-2.0);
        licenseFile       = (https://www.apache.org/licenses/LICENSE-2.0.txt);
        repository        = maven;
        downloadType      = binaries;
    };

    build-system = copysrc;

    build-tools = {
        1.0.x = {
            CopySrcBuild = 1.0;
        };
    };

    dependencies = {
        1.0.x = {
            AwsSmithyKotlinHttpClient = 1.0.x;
            KotlinStdlib              = 2.x;
        };
    };

    runtime-dependencies = {
        1.0.x = {
            AwsSmithyKotlinRuntimeCore       = 1.0.x;
            AwsSmithyKotlinTelemetryDefaults = 1.0.x;
            OkHttp3                          = 5.x;
            OkHttp3Coroutines                = 5.x;
            KotlinxCoroutinesCoreJvm         = 1.x;
        };
    };

    resolves-conflict-dependencies = {
        1.0.x = {
            KotlinStdlib             = 2.x;
            KotlinxCoroutinesCoreJvm = 1.x;
            KotlinStdlibJdk7         = 2.x;
            KotlinStdlibJdk8         = 2.x;
        };
    };

    targets = {
        http-client-engine-okhttp-jvm = { type = javalibrary; };
    };
};
