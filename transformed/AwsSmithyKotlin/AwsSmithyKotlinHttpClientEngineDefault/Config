# -*-perl-*-

package.AwsSmithyKotlinHttpClientEngineDefault = {
    interfaces = (1.0.x);

    third-party-configuration = {
        thirdPartyName    = "aws.smithy.kotlin:http-client-engine-default-jvm";
        thirdPartyVersion = "1.6.10";
        licenseType       = (Apache-2.0);
        licenseFile       = (https://www.apache.org/licenses/LICENSE-2.0.txt);
        repository        = maven;
        downloadType      = binaries;
    };

    build-system = copysrc;

    build-tools = {
        1.0.x = {
            CopySrcBuild = 1.0;
        };
    };

    dependencies = {
        1.0.x = {
            AwsSmithyKotlinHttpClient = 1.0.x;
            KotlinStdlib              = 2.x;
        };
    };

    runtime-dependencies = {
        1.0.x = {
            AwsSmithyKotlinHttpClientEngineOkhttp = 1.0.x;
            KotlinxCoroutinesCoreJvm              = 1.x;
            AwsSmithyKotlinRuntimeCore            = 1.0.x;
        };
    };

    resolves-conflict-dependencies = {
        1.0.x = {
            KotlinxCoroutinesCoreJvm = 1.x;
        };
    };

    targets = {
        http-client-engine-default-jvm = { type = javalibrary; };
    };
};
