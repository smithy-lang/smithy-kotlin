# -*-perl-*-

package.AwsSmithyKotlinCodegen = {
    interfaces = (1.x);

    third-party-configuration = {
        thirdPartyName    = "aws.smithy.kotlin:codegen";
        thirdPartyVersion = "1.6.10";
        licenseType       = (Apache-2.0);
        licenseFile       = (https://www.apache.org/licenses/LICENSE-2.0.txt);
        repository        = maven;
        downloadType      = binaries;
    };

    build-system = copysrc;

    build-tools = {
        1.x = {
            CopySrcBuild = 1.0;
        };
    };

    dependencies = {
        1.x = {
            Maven-software-amazon-smithy_smithy-codegen-core = 1.x;
            Maven-software-amazon-smithy_smithy-waiters      = 1.x;
            KotlinStdlib                                     = 2.x;
        };
    };

    runtime-dependencies = {
        1.x = {
            Maven-software-amazon-smithy_smithy-rules-engine         = 1.x;
            Maven-software-amazon-smithy_smithy-aws-traits           = 1.x;
            Maven-software-amazon-smithy_smithy-protocol-traits      = 1.x;
            Maven-software-amazon-smithy_smithy-protocol-test-traits = 1.x;
            Maven-software-amazon-smithy_smithy-smoke-test-traits    = 1.x;
            Maven-jsoup                                              = 1.x;
        };
    };

    targets = {
        codegen = { type = javalibrary; };
    };
};
